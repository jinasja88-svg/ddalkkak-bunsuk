{
   "action": {
      "default_icon": {
         "128": "/images/icon.png",
         "16": "/images/icon.png",
         "32": "/images/icon.png",
         "48": "/images/icon.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "script.js" ],
      "match_origin_as_fallback": true,
      "matches": [ "*://*/*" ]
   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "ruleset_1",
         "path": "rules.json"
      } ]
   },
   "description": "스마트스토어 쿠팡 이커머스 통합 분석 솔루션",
   "host_permissions": [ "*://*/*" ],
   "icons": {
      "128": "/images/icon.png",
      "16": "/images/icon.png",
      "32": "/images/icon.png",
      "48": "/images/icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "스마트스토어 쿠팡 분석 - SMART DATA 스마트데이터",
   "permissions": [ "activeTab", "scripting", "tabs", "cookies", "declarativeNetRequest" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.6"
}
