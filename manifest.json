{
  "manifest_version": 3,
  "name": "딸깍분석",
  "version": "2.2.0",
  "description": "페이지 분석 + 검색 기반 AI 상품 분석 익스텐션",
  "permissions": ["activeTab", "scripting", "tabs"],
  "content_scripts": [{
    "js": ["coupWing.js"],
    "matches": ["https://wing.coupang.com/*"],
    "run_at": "document_end"
  }],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period"
      },
      "description": "딸깍분석 열기/닫기"
    }
  },
  "web_accessible_resources": [{
    "resources": ["panel.html", "config.js", "panel.js", "review.js"],
    "matches": ["https://*/*", "http://*/*"]
  }]
}
